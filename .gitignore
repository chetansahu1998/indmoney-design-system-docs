# Next.js
.next/
out/
build/

# Dependencies
node_modules/

# Env (NEVER commit secrets)
.env
.env.local
.env.*.local

# Service-account keys, OAuth tokens, downloaded credentials
.secrets/
*-sa.json
*service-account*.json
gen-lang-client-*.json
google-sheets-sa.json

# Generated tokens (built per-brand at deploy time)
lib/tokens/.generated/
lib/tokens-generated/

# Local SQLite (ds-service runs locally) — match anywhere under services/
**/services/ds-service/data/*.db
**/services/ds-service/data/*.db-journal
**/services/ds-service/data/*.db-wal
**/services/ds-service/data/*.db-shm
**/data/ds.db
**/data/ds.db-*
# Rendered screen assets — tenant data, not code.
**/services/ds-service/data/screens/
**/services/ds-service/data/canonical_trees/

# Go build artifacts
services/ds-service/bin/
services/ds-service/cmd/extractor/extractor

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# Vercel
.vercel

# Editor
.vscode/
.idea/

# Logs
logs/
*.log

# Sync staging dirs
/tmp/sync-staging-*
.env.local.bak

# Playwright artifacts
test-results/
playwright-report/
playwright/.cache/

# Claude Code worktrees + agent state
.claude/

# Sheet-sync binary + zipped plugin distribution
services/ds-service/sheets-sync
figma-plugin.zip
