# Next.js
.next/
out/
build/

# Dependencies
node_modules/

# Env (NEVER commit secrets)
.env
.env.local
.env.*.local

# Service-account keys, OAuth tokens, downloaded credentials
.secrets/
*-sa.json
*service-account*.json
gen-lang-client-*.json
google-sheets-sa.json

# Generated tokens (built per-brand at deploy time)
lib/tokens/.generated/
lib/tokens-generated/

# Local SQLite (ds-service runs locally) — match anywhere under services/
**/services/ds-service/data/*.db
**/services/ds-service/data/*.db-journal
**/services/ds-service/data/*.db-wal
**/services/ds-service/data/*.db-shm
**/data/ds.db
**/data/ds.db-*
# Rendered screen assets — tenant data, not code.
**/services/ds-service/data/screens/
**/services/ds-service/data/canonical_trees/
# Pipeline output: per-node PNG/SVG renders, screen image-fill cache,
# four-tier preview pyramid. Hundreds of MB per tenant, regenerable
# from the source Figma files via sheets-sync + Stage 9 prerender.
**/services/ds-service/data/assets/
**/services/ds-service/data/image-fills/
**/services/ds-service/data/preview-pyramid/

# Go build artifacts
services/ds-service/bin/
services/ds-service/cmd/extractor/extractor
services/ds-service/server
services/ds-service/bootstrap-tenant
services/ds-service/compress-trees
services/ds-service/svg-eligibility-bench
services/ds-service/zstd-bench

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# Source-of-truth Basier Circle dump — designer drops the .ttf bundle at
# the repo root; the four weights are copied into public/fonts/basier-circle/
# (which IS tracked) and served at /fonts/basier-circle/*.ttf. The folder
# below is a vendor artifact only.
/Basier Circle/

# Vercel
.vercel

# Editor
.vscode/
.idea/

# Logs
logs/
*.log

# Sync staging dirs
/tmp/sync-staging-*
.env.local.bak

# Playwright artifacts
test-results/
playwright-report/
playwright/.cache/

# Claude Code worktrees + agent state
.claude/

# Sheet-sync binary + zipped plugin distribution
services/ds-service/sheets-sync
figma-plugin.zip

# Diagnostic scratch — screenshots / recordings dropped in repo root or
# tests/ during debugging, ad-hoc render harness output, and local-only
# Go build artifacts from cmd/* one-shots. None of these are source.
/Screenshot *.png
"/Screen Recording *.mov"
/tests/Screenshot *.png
/tmp/
services/ds-service/import-figma-url
services/ds-service/variants
services/ds-service/data/*.bak*
services/ds-service/figma-*-sync
services/ds-service/figma-autosync-*
