    "next-themes": "^0.4.6",
    "pagefind": "^1.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.180.0",
    "vaul": "^1.1.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
