{
  "name": "indmoney-design-system-docs",
  "version": "0.0.1",
  "private": true,
  "description": "INDmoney Design System documentation site — Foundations + Components, Figma-synced",
  "scripts": {
    "dev": "tz build && next dev --port 3001",
    "build": "tz build && next build",
    "start": "next start --port 3001",
    "lint": "tsc --noEmit",
    "sync:tokens": "tsx scripts/sync-tokens.ts",
    "extract:figma": "cd services/ds-service && go run ./cmd/extractor",
    "audit": "cd services/ds-service && go run ./cmd/audit",
    "audit:serve": "cd services/ds-service && go run ./cmd/audit-server",
    "tokens:build": "tz build",
    "prebuild": "tz build",
    "test:parity": "playwright test --project=indmoney-light"
  },
