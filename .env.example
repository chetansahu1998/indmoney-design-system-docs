# INDmoney Design System Docs — environment variables
#
# Copy this file to `.env.local` for local development.
# NEVER commit `.env.local` (it's in .gitignore).

# ─── Brand selection (Vercel sets this per-project) ────────────────────────────
NEXT_PUBLIC_BRAND=indmoney   # indmoney | tickertape

# ─── Figma extraction (used by services/ds-service Go binary) ──────────────────
# PAT scopes needed: file_content:read (file_variables:read if Enterprise)
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_PAT=figd_REPLACE_ME

# Production app file (token source via display extraction):
FIGMA_FILE_KEY_INDMONEY=2m7ouydXKfxYk7hhjQxrt7
# Glyph design system file (text styles only):
FIGMA_FILE_KEY_INDMONEY_GLYPH=ePcuKLNGHwSubsfaiaryJv
# Tickertape: not yet provided
FIGMA_FILE_KEY_TICKERTAPE=

# ─── ds-service local Go service ───────────────────────────────────────────────
DS_SERVICE_URL=http://localhost:8080
SQLITE_PATH=./services/ds-service/data/ds.db

# JWT signing key (Ed25519 base64). Generate with:
#   go run ./services/ds-service/scripts/genkey.go
JWT_SIGNING_KEY=REPLACE_ME_WITH_BASE64_ED25519_PRIVATE
JWT_PUBLIC_KEY=REPLACE_ME_WITH_BASE64_ED25519_PUBLIC

# AES-GCM key for encrypting per-tenant Figma PATs in SQLite.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_ME_BASE64_32_BYTES

# ─── Cloudflare Tunnel (production exposure) ───────────────────────────────────
# Set after running `cloudflared tunnel create indmoney-ds-tunnel`
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_HOSTNAME=api.ds.indmoney.dev   # adjust to your domain

# ─── GitHub (sync writes commits via local git, not GitHub App in v1) ──────────
# Sync orchestrator just runs `git add && git commit && git push` against the local checkout.
GITHUB_REPO=indmoney/design-system-docs   # owner/repo for docs links
