# INDmoney Design System Docs — environment variables
#
# Copy this file to `.env.local` for local development.
# NEVER commit `.env.local` (it's in .gitignore).

# ─── Brand selection (Vercel sets this per-project) ────────────────────────────
NEXT_PUBLIC_BRAND=indmoney   # indmoney | tickertape

# ─── Figma extraction (used by services/ds-service Go binary) ──────────────────
# PAT scopes needed: file_content:read (file_variables:read if Enterprise)
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_PAT=figd_REPLACE_ME

# ─── Sources: multi-file, multi-node pooling ───────────────────────────────────
# The extractor accepts MULTIPLE sources, pools observations across them.
# Source spec format: kind:file_key[:node_id]
#   kind ∈ {design-system, product}
#   - design-system: contributes text styles (from /styles endpoint) + optional pair-walk on a node
#   - product:       contributes pair-walker observations from production light/dark renderings
# Multiple sources can be configured by:
#   (a) FIGMA_SOURCES env (comma-separated)
#   (b) Per-brand auto-derive (default — see below)
#   (c) --source CLI flags (override env)
#
# Auto-derive: the extractor uses these per-brand vars to build a default source list.

# Glyph (system file): contributes 18 published TEXT styles
FIGMA_FILE_KEY_INDMONEY_GLYPH=ePcuKLNGHwSubsfaiaryJv
# FIGMA_NODE_ID_INDMONEY_GLYPH=  # optional — set if Glyph has a token-display section worth pair-walking

# INDstocks V4 (product file): contributes pair-walker observations
FIGMA_FILE_KEY_INDMONEY=2m7ouydXKfxYk7hhjQxrt7
FIGMA_NODE_ID_INDMONEY=9578:198724  # 'Phase 1' SECTION; remove to scan whole file at depth=4

# Add more product sources by setting FIGMA_SOURCES manually, e.g.:
# FIGMA_SOURCES=design-system:ePcuKLNG...,product:2m7ouy...:9578:198724,product:2m7ouy...:other_section_id

# Tickertape: not yet provided
FIGMA_FILE_KEY_TICKERTAPE=

# ─── ds-service local Go service ───────────────────────────────────────────────
DS_SERVICE_URL=http://localhost:8080
SQLITE_PATH=./services/ds-service/data/ds.db

# JWT signing key (Ed25519 base64). Generate with:
#   go run ./services/ds-service/scripts/genkey.go
JWT_SIGNING_KEY=REPLACE_ME_WITH_BASE64_ED25519_PRIVATE
JWT_PUBLIC_KEY=REPLACE_ME_WITH_BASE64_ED25519_PUBLIC

# AES-GCM key for encrypting per-tenant Figma PATs in SQLite.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_ME_BASE64_32_BYTES

# ─── Cloudflare Tunnel (production exposure) ───────────────────────────────────
# Set after running `cloudflared tunnel create indmoney-ds-tunnel`
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_HOSTNAME=api.ds.indmoney.dev   # adjust to your domain

# ─── Feature flags (Phase 5.1+) ────────────────────────────────────────────────
# DRD collaborative editor (Yjs + Hocuspocus sidecar). Set to "1" only when
# the Hocuspocus sidecar is reachable at the URL `lib/drd/collab.ts` resolves
# (today: `ws://localhost:8090/<flow_id>?token=…`). Leaving this unset (or any
# value other than "1") falls through to the single-author REST DRDTab — the
# safe default. See `components/projects/tabs/DRDTabCollab.tsx` for what the
# flag toggles + which backend dependencies it pulls in.
NEXT_PUBLIC_DRD_COLLAB=

# How long (ms) the project shell sits in `pending` before surfacing the
# "slow to render — refresh?" affordance. Defaults to 60_000 (60s) — large
# exports legitimately take 30-60s through the full pipeline, so anything
# tighter trains users to refresh into a half-baked render. Tighten only
# if your env's pipeline SLA is genuinely faster.
NEXT_PUBLIC_PROJECT_SLOW_RENDER_MS=

# ─── GitHub (sync writes commits via local git, not GitHub App in v1) ──────────
# Sync orchestrator just runs `git add && git commit && git push` against the local checkout.
GITHUB_REPO=indmoney/design-system-docs   # owner/repo for docs links
