{
  "name": "INDmoney DS Sync",
  "id": "indmoney-ds-sync",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "documentAccess": "dynamic-page",
  "editorType": ["figma"],
  "networkAccess": {
    "allowedDomains": [
      "https://api.figma.com",
      "https://indmoney-design-system-docs.vercel.app",
      "http://localhost:3001",
      "http://localhost:7474"
    ],
    "reasoning": "Talks to the docs site / ds-service to push selections, fetch tokens, and inject the latest extracted components and icons."
  },
  "permissions": ["currentuser"],
  "menu": [
    { "name": "Sync selection to docs",  "command": "syncSelection" },
    { "name": "Inject latest icons",     "command": "injectIcons" },
    { "name": "Inject latest components","command": "injectComponents" },
    { "name": "Open docs site",          "command": "openDocsSite" }
  ]
}
