{
  "name": "INDmoney DS Sync",
  "id": "indmoney-ds-sync",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "documentAccess": "dynamic-page",
  "editorType": ["figma"],
  "networkAccess": {
    "allowedDomains": [
      "https://api.figma.com",
      "https://indmoney-design-system-docs.vercel.app",
      "https://ds-service.indmoney.com",
      "http://localhost:3001",
      "http://localhost:7474",
      "http://localhost:7475"
    ],
    "reasoning": "Talks to the docs site / ds-service to push selections, fetch tokens, inject extracted components and icons, and export Projects (Flow Atlas) flows."
  },
  "permissions": ["currentuser", "teamlibrary"],
  "menu": [
    { "name": "Publish selection to DS", "command": "publishSelection" },
    { "separator": true },
    { "name": "Audit selection",         "command": "auditSelection" },
    { "name": "Audit file",              "command": "auditFile" },
    { "separator": true },
    { "name": "Open Projects mode",      "command": "openProjects" },
    {
      "name":       "Apply auto-fix from docs",
      "command":    "autofix",
      "parameters": [
        { "name": "Project slug",  "key": "slug",         "description": "From the docs URL — e.g. tax-fno-learn" },
        { "name": "Violation id",  "key": "violation_id", "description": "Violation UUID from the Fix-in-Figma button" }
      ],
      "parameterOnly": false
    },
    { "separator": true },
    { "name": "Open docs site",          "command": "openDocsSite" }
  ]
}
