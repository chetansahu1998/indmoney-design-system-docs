{
  "name": "INDmoney DS Sync",
  "id": "indmoney-ds-sync",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "documentAccess": "dynamic-page",
  "editorType": ["figma"],
  "networkAccess": {
    "allowedDomains": [
      "https://api.figma.com",
      "https://indmoney-design-system-docs.vercel.app",
      "http://localhost:3001",
      "http://localhost:7474"
    ],
    "reasoning": "Talks to the docs site / ds-service to push selections, fetch tokens, and inject the latest extracted components and icons."
  },
  "permissions": ["currentuser", "teamlibrary"],
  "menu": [
    { "name": "Publish selection to DS", "command": "publishSelection" },
    { "separator": true },
    { "name": "Audit selection",         "command": "auditSelection" },
    { "name": "Audit file",              "command": "auditFile" },
    { "separator": true },
    { "name": "Open docs site",          "command": "openDocsSite" }
  ]
}
